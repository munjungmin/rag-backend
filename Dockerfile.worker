FROM python:3.13-slim

WORKDIR /app

# 시스템 의존성 설치 (unstructured hi_res에 필요)
RUN apt-get update && apt-get install -y \
    libgl1 \
    libglib2.0-0 \
    poppler-utils \
    tesseract-ocr \
    libmagic1 \
    && rm -rf /var/lib/apt/lists/*

# 의존성 먼저 설치 (캐싱 활용)
COPY requirements-worker.txt .
RUN pip install --no-cache-dir -r requirements-worker.txt

# 코드는 볼륨 마운트로 주입 (이미지 재빌드 없이 코드 변경 가능)

CMD ["celery", "-A", "tasks", "worker", "--loglevel=info", "--pool=threads"]
